# 外部房價估值服務 (miaogu) 的 base URL, 到 port 為止
# 例如本機: http://localhost:8004
# 正式環境: http://your-host:8004
MORTGAGE_URL=http://localhost:8004

# OpenAI API 金鑰，PDF 分析端點 (/api/pdf-analysis) 使用
OPENAI_API_KEY=sk-...
# 解析用模型，可省略，預設 gpt-4o
# OPENAI_MODEL=gpt-4o

# AES 共享 passphrase：前端加密 createProject 的 data，後端用同一組解密。
# 兩端必須一致；前端常數也要同步改成這個值。
AES_PASSPHRASE=land-info-dev-passphrase
